# CoinGecko
COINGECKO_API_URL=https://api.coingecko.com/api/v3/simple/price
COINGECKO_COIN_IDS=bitcoin,ethereum,solana
POLL_INTERVAL_SECONDS=60

# Kafka (use DOCKER listener from inside compose network)
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_TOPIC=coingecko.prices.raw

# Binance WebSocket ingest
BINANCE_KAFKA_TOPIC=binance.trades.raw
BINANCE_STREAMS=btcusdt@trade,ethusdt@trade,solusdt@trade
BINANCE_THROTTLE_SECONDS=1
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443

# Metabase dashboard import (metabase/setup_dashboard.py)
METABASE_URL=http://localhost:3000
METABASE_EMAIL=
METABASE_PASSWORD=

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cryptopulse
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse

# Transform (Dagster + dbt + Great Expectations)
TRANSFORM_INTERVAL_SECONDS=300
GE_FRESHNESS_MINUTES=10
GE_MIN_ROWS_PER_SOURCE=1
GE_MIN_COINS_PER_SOURCE=3
DAGSTER_PORT=3002

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# MinIO (S3-compatible data lake — storage layer)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=crypto-pulse
LAKE_RAW_PREFIX=raw/crypto_prices

# Kafka resilience
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_TOPIC_RETENTION_MS=604800000
KAFKA_TOPIC_PARTITIONS=3
KAFKA_PRODUCER_RETRIES=10

# Flink watchdog (resubmit job if none running)
FLINK_WATCHDOG_INTERVAL_SECONDS=60
