      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(crypto_pulse_messages_published_total[5m])) + sum(rate(crypto_pulse_binance_messages_published_total[5m]))",
          "legendFormat": "messages/s",
          "refId": "A"
        }
      ],
      "title": "Ingest throughput (CoinGecko + Binance)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "crypto_pulse_last_price_usd",
          "legendFormat": "{{coin_id}}",
          "refId": "A"
        }
      ],
      "title": "Last published price (ingest)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag{consumergroup=~\"flink-crypto-pulse-.*\"})",
          "legendFormat": "flink consumer lag",
          "refId": "A"
        }
      ],
      "title": "Kafka consumer lag (Flink)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(flink_taskmanager_job_task_numRecordsOut[5m]))",
          "legendFormat": "records out/s",
          "refId": "A"
        }
      ],
      "title": "Flink records out",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(crypto_pulse_api_errors_total[1h]))",
          "refId": "A"
        }
      ],
      "title": "Ingest errors (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "time() - crypto_pulse_last_successful_poll_timestamp",
          "refId": "A"
        }
      ],
      "title": "Seconds since last CoinGecko poll",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
