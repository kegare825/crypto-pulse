      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(crypto_pulse_binance_ws_errors_total[1h]))",
          "refId": "A"
        }
      ],
      "title": "Binance WS errors (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 20 },
      "id": 9,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(crypto_pulse_binance_messages_published_total[10m]))",
          "refId": "A"
        }
      ],
      "title": "Binance messages (10m)",
      "type": "stat"
